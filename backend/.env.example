OLLAMA_BASE_URL=http://ollama:11434
# Recommended models for document analysis:
#   llama3.2:3b   - Best for Mac/low-RAM systems (~2GB, fast & accurate)
#   llama3:8b     - Best quality but needs 8GB+ RAM
#   phi3:mini     - Alternative lightweight option (~2.3GB)
LLM_MODEL=llama3.2:3b
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=500
CHUNK_OVERLAP=50
FAISS_INDEX_PATH=./data/faiss_index
UPLOAD_DIR=./data/uploads
DATABASE_URL=postgresql+asyncpg://avanam:avanam@localhost:5432/avanam
REDIS_URL=redis://localhost:6379/0
CRITIC_CONFIDENCE_THRESHOLD=0.7
MAX_REVISION_LOOPS=2
LOG_LEVEL=INFO
