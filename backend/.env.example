LLM_PROVIDER=groq # Options: gemini, groq, ollama
GOOGLE_API_KEY=your-gemini-api-key-here
GROQ_API_KEY=your-groq-api-key-here
OLLAMA_BASE_URL=http://ollama:11434
# For Groq: llama3-70b-8192, For Ollama: llama3, For Gemini: gemini-2.0-flash
LLM_MODEL=llama3-70b-8192
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=500
CHUNK_OVERLAP=50
FAISS_INDEX_PATH=./data/faiss_index
UPLOAD_DIR=./data/uploads
DATABASE_URL=postgresql+asyncpg://avanam:avanam@localhost:5432/avanam
REDIS_URL=redis://localhost:6379/0
CRITIC_CONFIDENCE_THRESHOLD=0.7
MAX_REVISION_LOOPS=2
LOG_LEVEL=INFO
